# Database Configuration

# For local development with PostgreSQL
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_USER=your_db_user
LOCAL_DB_PASS=your_db_password
LOCAL_DB_NAME=therapists

# For production (Supabase or other hosted PostgreSQL)
PROD_DB_HOST=your_prod_host
PROD_DB_PORT=5432
PROD_DB_USER=your_prod_user
PROD_DB_PASS=your_prod_password
PROD_DB_NAME=your_prod_db_name

# Environment
ENVIRONMENT=local  # Options: local, development, production
